@using INF_Senior_Project.ViewModels
@model InventoryDashboardViewModel

<h2>Inventory</h2>

<form method="get">
    <input type="text" name="search" placeholder="Search..." />
    <button type="submit">Search</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th><a href="?sortOrder=name_desc">Name</a></th>
            <th>Category</th>
            <th><a href="?sortOrder=price">Price</a></th>
            <th><a href="?sortOrder=quantity">Quantity</a></th>
            <th><a href="?sortOrder=exp">Expiration</a></th>
            <th>Supplier</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Products)
        {
            <tr class="@(item.Quantity < 10 ? "table-danger" : "")">
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>@item.ExpirationDate.ToShortDateString()</td>
                <td>@item.Supplier?.Name</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-primary">Add Product</a>

                

<h2>Suppliers</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th style="width: 200px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Suppliers)
        {
            <tr>
                <td>@item.Name</td>

                <td>
                    <a asp-action="EditSupplier" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="DeleteSupplier" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<br />

<a asp-action="CreateSupplier" class="btn btn-primary">Add Supplier</a>