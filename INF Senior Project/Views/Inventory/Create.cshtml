@using INF_Senior_Project.Models
@model Product
@using Microsoft.AspNetCore.Mvc.Rendering


<h2>Add Product</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div>
        <label>Category</label>
        <input asp-for="Category" class="form-control" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" />
    </div>

    <div>
        <label>Quantity</label>
        <input asp-for="Quantity" type="number" class="form-control" />
    </div>

    <div>
        <label>Expiration Date</label>
        <input asp-for="ExpirationDate" type="date" class="form-control" />
    </div>

    <div>
        <label>Supplier</label>
        <select asp-for="SupplierId" class="form-control" asp-items="ViewBag.Suppliers">
            <option value="">-- Select Supplier --</option> <!-- optional placeholder -->
        </select>
        <span asp-validation-for="SupplierId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>