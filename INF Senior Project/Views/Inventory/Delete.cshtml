@model INF_Senior_Project.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<h2>Are you sure you want to delete this product?</h2>

<div>
    <h3>@Model.Name</h3>
    <p>Category: @Model.Category</p>
    <p>Price: @Model.Price</p>
    <p>Quantity: @Model.Quantity</p>
    <p>Expiration Date: @Model.ExpirationDate.ToShortDateString()</p>
    <p>Supplier: @Model.Supplier.Name</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="@Url.Action("InventoryDashboard", "Inventory")" class="btn btn-secondary">Cancel</a>
</form>