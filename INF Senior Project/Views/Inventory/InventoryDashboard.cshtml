@model IEnumerable<Product>

<h2>Inventory</h2>

<form method="get">
    <input type="text" name="search" placeholder="Search..." />
    <button type="submit">Search</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th><a href="?sortOrder=name_desc">Name</a></th>
            <th>Category</th>
            <th><a href="?sortOrder=price">Price</a></th>
            <th><a href="?sortOrder=quantity">Quantity</a></th>
            <th><a href="?sortOrder=exp">Expiration</a></th>
            <th>Supplier</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.Quantity < 10 ? "table-danger" : "")">
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>@item.ExpirationDate.ToShortDateString()</td>
                <td>@item.Supplier?.Name</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-primary">Add Product</a>