@model INF_Senior_Project.Models.Supplier
@{
    ViewData["Title"] = "Delete Supplier";
}

<h2>Are you sure you want to delete this Supplier?</h2>

<div>
    <h3>@Model.Name</h3>
</div>

<form asp-action="DeleteSupplier" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <div asp-validation-summary="All" class="text-danger"></div>
    <a href="@Url.Action("Dashboard", "Inventory")" class="btn btn-secondary">Cancel</a>
</form>