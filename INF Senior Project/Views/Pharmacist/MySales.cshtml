@model INF_Senior_Project.ViewModels.MySalesViewModel

<h2>My Sales</h2>

<h4>Total Revenue: @Model.TotalRevenue.ToString("F2")</h4>

<table class="table">
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Total Amount</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.OrderDate</td>
                <td>@order.TotalAmount.ToString("F2")</td>
                <td>
                    <a class="btn btn-sm btn-primary" asp-controller="Pharmacist" asp-action="OrderDetails" asp-route-id="@order.Id">
                        View
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>